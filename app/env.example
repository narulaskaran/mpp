# MPP Demo — environment variables
# Copy to .env.local for local dev

# --- Required ---
# Ethereum wallet address to receive Tempo payments
TEMPO_RECIPIENT=YOUR_WALLET_ADDRESS

# Secure random secret for MPP challenge signing (generate with: openssl rand -base64 32)
MPP_SECRET_KEY=

# Default Tempo token contract address when no ?testnet= override is present.
# Standard defaults are used when omitted:
# - mainnet USDC.e: 0x20C000000000000000000000b9537d11c60E8b50
# - testnet pathUSD: 0x20c0000000000000000000000000000000000000
TEMPO_CURRENCY=YOUR_TEMPO_TOKEN_CONTRACT_ADDRESS

# Private key of wallet that funds OpenAI calls on the on-chain route
TEMPO_RECIPIENT_KEY=YOUR_PRIVATE_KEY

# Default on-chain network when no ?testnet= override is present.
# Set to "false" for mainnet (must match your STRIPE_SECRET_KEY mode on /paid/stripe — sk_live_ → false)
# TEMPO_TESTNET=true

# --- Optional ---
# RPC endpoint when no ?testnet= override is present
# TEMPO_RPC_URL=https://rpc.tempo.xyz

# Network-specific overrides used by /paid/onchain?testnet=true or ?testnet=false
# TEMPO_TESTNET_CURRENCY=0x20c0000000000000000000000000000000000000
# TEMPO_MAINNET_CURRENCY=0x20C000000000000000000000b9537d11c60E8b50
# TEMPO_TESTNET_RPC_URL=https://rpc.moderato.tempo.xyz
# TEMPO_MAINNET_RPC_URL=https://rpc.tempo.xyz

# Address to sweep funds to after each on-chain payment
# SWEEP_TO=YOUR_SWEEP_DESTINATION_ADDRESS

# Private key of fee-payer account (sponsors gas so agents don't need gas tokens)
# FEE_PAYER_KEY=YOUR_FEE_PAYER_PRIVATE_KEY

# Payment amount in USDC for on-chain Tempo route (default: 0.99)
# PAYMENT_AMOUNT=0.99

# --- Stripe ---
# Enables crypto (USDC.e) and SPT (USD) payment routes
STRIPE_SECRET_KEY=sk_...
STRIPE_PROFILE_ID=profile_...

# Payment amount in USD for Stripe SPT route (default: 0.99)
# STRIPE_PAYMENT_AMOUNT=0.99
